# =========================================================================
#  Modelo do .env.local — COPIE, não edite este arquivo.
#
#      cp .env.example .env.local
#
#  O .env.local está no .gitignore e NUNCA sobe pro GitHub. É onde ficam os
#  segredos operacionais (deploy). A página em si não lê nenhuma dessas
#  variáveis em runtime: ela é 100% estática (output: 'export').
# =========================================================================

# --- Coolify (deploy) -----------------------------------------------------
# Token de API da Coolify. Painel: Keys & Tokens > API tokens.
COOLIFY_API_TOKEN=

# URL da instância da Coolify (ex.: https://coolify.seudominio.com)
COOLIFY_URL=

# UUID da aplicação da mentoria dentro da Coolify (aparece na URL do app).
COOLIFY_APP_UUID=
